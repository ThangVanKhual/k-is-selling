        "message": "=Hello {{ $(\"Generate Ticket ID\").item.json.Name || \"there\" }},<br><br>We received your support request and created ticket <strong>{{ $(\"Generate Ticket ID\").item.json[\"Ticket ID\"] }}</strong>.<br><br><strong>Type:</strong> {{ $(\"Generate Ticket ID\").item.json[\"Ticket Type\"] }}<br><strong>Subject:</strong> {{ $(\"Generate Ticket ID\").item.json.Subject }}<br><br>Our team will review it and follow up soon.<br><br>Thank you,<br>Support Team",
        "options": {
          "appendAttribution": false
        }
      },
      "id": "<REDACTED_ID_007>",
      "name": "Send Customer Confirmation",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.2,
      "position": [
        672,
        192
