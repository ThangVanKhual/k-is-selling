              "type": "string"
            },
            {
              "id": "<REDACTED_ID_003>",
              "name": "Ticket Status",
              "value": "Open",
              "type": "string"
            },
            {
              "id": "<REDACTED_ID_004>",
              "name": "Created At",
              "value": "={{ $now.toISO() }}",
              "type": "string"
